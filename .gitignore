# ── 项目根 .gitignore（约定，即便当前非 git 仓库也保留）──

# 运行时日志（按日期轮转，落盘到项目根 logs/）
# 详见 logs/README.md
logs/

# 依赖
node_modules/

# 构建产物
backend/dist/
frontend/.next/
frontend/out/
frontend/dist/

# 环境变量 / 密钥
.env
.env.*
!.env.example

# 数据库 & 本地数据
*.db
*.db-journal
backend/data/

# 测试覆盖率报告
backend/coverage/

# 工具缓存
.gstack/

# Windows 保留名
nul

# 归档/备份产物（P2-1）
*.tar.gz
*.pid

# TTS 运行时生成的音频（静态托管目录，内容运行时产出）
backend/static/audio/

# PWA 构建生成的 service worker（next-pwa 构建产物）
frontend/public/sw.js
frontend/public/workbox-*.js
