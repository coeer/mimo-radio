# Server
PORT=8000
NODE_ENV=development

# Auth
# API_KEY: required in production for all /api/* routes
API_KEY=your-secure-api-key-min-16-chars
# SESSION_SECRET: used to sign session tokens (HMAC-SHA256)
SESSION_SECRET=your-session-secret-min-32-chars

# MiMo (小米大模型) - 默认 AI 大脑 + TTS/ASR
# Base URL 二选一：
#   赠送 Token Plan: https://token-plan-cn.xiaomimimo.com/v1
#   按量计费: https://api.xiaomimimo.com/v1
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_DEFAULT_MODEL=mimo-v2.5

# MiMo TTS（多引擎，全部复用上面的 MIMO_API_KEY，Token Plan 限时免费）
# 启动默认引擎：mimo-tts / mimo-design / mimo-clone
TTS_ENGINE=mimo-tts
# 预置音色（苏打=男电台 / 冰糖=女清甜 / 茉莉=女知性 / 白桦=男大气 / Mia/Chloe/Milo/Dean=英文）
MIMO_TTS_VOICE=苏打
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_DESIGN_MODEL=mimo-v2.5-tts-voicedesign
MIMO_TTS_CLONE_MODEL=mimo-v2.5-tts-voiceclone
# MiMo ASR（语音转文字，为未来语音点歌预留）
MIMO_ASR_MODEL=mimo-v2.5-asr

# OpenWeather
OPENWEATHER_API_KEY=your-key
OPENWEATHER_CITY=Beijing
OPENWEATHER_LAT=39.9042
OPENWEATHER_LON=116.4074

# Netease Music (optional, for playlist sync)
NETEASE_COOKIE=
